# Токен для авторизации в API Odin
ODIN_BEARER_TOKEN=your_token_here
ODIN_AUTHORIZATIONSTORE={"jwtToken":"your_jwtToken_here","jwtTokenDateOfCreation":your_jwtTokenDateOfCreation_here}

DB_NAME=odin
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# S3/MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=odin-worker
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=false